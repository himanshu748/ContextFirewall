# ===== ContextFirewall backend configuration (EXAMPLE) =====
# Copy to .env for local dev (.env is gitignored). On the Hugging Face Space,
# set these as Space environment variables instead. NEVER commit a real .env.

# --- LLM: chat / graph extraction (cognify), via the Hugging Face router ---
HUGGINGFACE_API_KEY=hf_your_token_here
LLM_API_KEY=hf_your_token_here
HF_TOKEN=hf_your_token_here
LLM_PROVIDER=custom
# Pin the HF router provider with ":novita" — the bare model auto-routes and can 403.
LLM_MODEL=openai/Qwen/Qwen2.5-72B-Instruct:novita
LLM_ENDPOINT=https://router.huggingface.co/v1
# HF router providers reject response_format=json_object; use markdown-JSON.
LLM_INSTRUCTOR_MODE=markdown_json_mode

# --- Embeddings: Hugging Face router feature-extraction API (no local model) ---
EMBEDDING_PROVIDER=hf_router
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=16
# EMBEDDING_ENDPOINT=  # optional override; default derives from EMBEDDING_MODEL

# --- Cognee posture: single-tenant dev tool ---
ENABLE_BACKEND_ACCESS_CONTROL=false
CACHING=false
COGNEE_SKIP_CONNECTION_TEST=true

# --- Data location (dev local stores live here; gitignored) ---
CF_DATA_DIR=./.cf_data

# ============================================================
# PROD (Hugging Face Space): externalize durable storage so the
# backend stays stateless. Leave unset for local dev.
# ============================================================
# Relational (Supabase Postgres):
# DB_PROVIDER=postgres
# DB_HOST=db.<project-ref>.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=
# Vector (pgvector on the same Supabase Postgres):
# VECTOR_DB_PROVIDER=pgvector
# Graph (Neo4j Aura):
# GRAPH_DATABASE_PROVIDER=neo4j
# GRAPH_DATABASE_URL=neo4j+s://<id>.databases.neo4j.io
# GRAPH_DATABASE_USERNAME=neo4j
# GRAPH_DATABASE_PASSWORD=
